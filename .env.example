# All variables are optional. Run `myfitnesspal-mcp auth` for the guided setup instead.

# MyFitnessPal session cookie: either the full Cookie header from a logged-in
# browser request, or just the value of __Secure-next-auth.session-token.
# MFP_COOKIE=

# Your MyFitnessPal username (not email). Only needed if MFP's profile endpoint
# fails for your account (the server will tell you).
# MFP_USERNAME=

# Browser fingerprint for Cloudflare. Try chrome124 etc. if you get 403s.
# MFP_IMPERSONATE=chrome

# How many days back to gap-fill the local cache (default 30).
# MFP_SYNC_DAYS=30

# Where to keep the local SQLite cache (default: platform data dir).
# MFP_MCP_DATA_DIR=
